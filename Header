<!-- ============================================ -->
<!-- CALENDAR COMPONENT (For Posting Schedule) -->
<!-- ============================================ -->
<div class="calendar-section">
  <div class="calendar-header">
    <h2>Posting Schedule</h2>
    <div class="view-toggle">
      <button id="timelineView" class="view-btn active">Timeline</button>
      <button id="calendarView" class="view-btn">Calendar</button>
    </div>
  </div>

  <!-- Timeline View -->
  <div id="timelinePanel" class="panel active">
    <div class="empty-state" id="emptyTimeline">
      <div class="empty-icon">📅</div>
      <p>No scheduled posts yet</p>
      <button class="btn-primary" onclick="openScheduleModal()">Schedule First Post</button>
    </div>
    <div class="timeline-list" id="timelineList"></div>
  </div>

  <!-- Calendar View -->
  <div id="calendarPanel" class="panel">
    <div class="calendar-nav">
      <button id="prevMonth">‹</button>
      <h3 id="currentMonth">January 2025</h3>
      <button id="nextMonth">›</button>
    </div>
    <div class="calendar-grid" id="calendarGrid">
      <!-- Generated by JS -->
    </div>
  </div>
</div>

<!-- Day Detail Modal -->
<div class="modal" id="dayModal" style="display: none;">
  <div class="modal-content">
    <div class="modal-header">
      <h3 id="selectedDate">January 15, 2025</h3>
      <button class="close-btn" onclick="closeDayModal()">×</button>
    </div>
    <div class="modal-body">
      <div class="day-posts" id="dayPosts">
        <!-- Posts for selected day -->
      </div>
      <button class="btn-primary" onclick="openScheduleModalForDate()">
        + Schedule Post for This Day
      </button>
    </div>
  </div>
</div>

<!-- ============================================ -->
<!-- PLATFORM CONNECTION (Updated) -->
<!-- ============================================ -->
<div class="platforms-section" id="connected-platforms">
  <div class="section-header">
    <h2>🔗 Connected Platforms</h2>
  </div>
  
  <div class="platforms-grid" id="platformsList">
    <!-- Platforms loaded dynamically -->
  </div>
  
  <button class="add-platform-btn" onclick="showAddPlatformModal()">
    <span>+</span> Add Platform
  </button>
</div>

<!-- Platform Auth Modal -->
<div class="modal" id="platformAuthModal" style="display: none;">
  <div class="modal-content auth-modal">
    <h3>Connect <span id="authPlatformName">Platform</span></h3>
    <p>You'll be redirected to authorize SocialSync to create posts on your behalf.</p>
    <div class="permissions-list" id="authPermissions">
      <!-- Permissions listed here -->
    </div>
    <div class="modal-actions">
      <button class="btn-secondary" onclick="closeAuthModal()">Cancel</button>
      <button class="btn-primary" id="confirmAuthBtn" onclick="startPlatformAuth()">
        Connect Account
      </button>
    </div>
  </div>
</div>

<!-- ============================================ -->
<!-- AI CONTENT TOOLS -->
<!-- ============================================ -->
<div class="ai-tools-section" id="ai-tools">
  <h2>🤖 AI Content Studio</h2>
  
  <div class="ai-tabs">
    <button class="ai-tab active" data-tab="inspiration">Video Inspiration</button>
    <button class="ai-tab" data-tab="hashtags">Hashtag Generator</button>
    <button class="ai-tab" data-tab="ideas">Content Ideas</button>
  </div>
  
  <!-- Video Inspiration Tab -->
  <div class="ai-panel active" id="inspirationPanel">
    <div class="search-box">
      <input type="text" id="inspirationSearch" placeholder="Search for video inspiration (e.g., 'fitness motivation', 'cooking tips')">
      <button onclick="searchInspiration()">Search</button>
    </div>
    <div class="filters">
      <select id="videoOrientation">
        <option value="portrait">Portrait (9:16)</option>
        <option value="landscape">Landscape (16:9)</option>
      </select>
      <select id="videoDuration">
        <option value="short">Short (< 60s)</option>
        <option value="medium">Medium (1-5 min)</option>
        <option value="long">Long (> 5 min)</option>
      </select>
    </div>
    <div class="video-grid" id="inspirationResults">
      <!-- Results populated by JS -->
    </div>
  </div>
  
  <!-- Hashtag Generator Tab -->
  <div class="ai-panel" id="hashtagsPanel">
    <div class="search-box">
      <input type="text" id="hashtagTopic" placeholder="Enter your video topic">
      <select id="hashtagPlatform">
        <option value="tiktok">TikTok</option>
        <option value="instagram">Instagram</option>
        <option value="youtube">YouTube</option>
      </select>
      <button onclick="generateHashtags()">Generate Hashtags</button>
    </div>
    <div class="hashtags-results" id="hashtagsResults">
      <!-- Generated hashtags -->
    </div>
  </div>
  
  <!-- Content Ideas Tab -->
  <div class="ai-panel" id="ideasPanel">
    <div class="search-box">
      <input type="text" id="contentNiche" placeholder="Your niche (e.g., fitness, tech, cooking)">
      <select id="contentPlatform">
        <option value="tiktok">TikTok</option>
        <option value="instagram">Instagram</option>
        <option value="youtube">YouTube</option>
      </select>
      <button onclick="getContentIdeas()">Get Ideas</button>
    </div>
    <div class="ideas-list" id="ideasResults"></div>
  </div>
</div>
